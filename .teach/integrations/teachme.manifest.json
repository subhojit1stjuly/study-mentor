{
  "integration": "teachme",
  "version": "0.1.0",
  "description": "Teach Me - Personalized skill learning system inspired by spec-kit",
  "installed_at": "2026-06-11T00:00:00.000000+00:00",
  "files": {
    ".teach/scripts/powershell/check-prerequisites.ps1": "checksum-placeholder",
    ".teach/scripts/powershell/common.ps1": "checksum-placeholder",
    ".teach/scripts/powershell/create-new-skill.ps1": "checksum-placeholder",
    ".teach/scripts/powershell/setup-roadmap.ps1": "checksum-placeholder",
    ".teach/scripts/powershell/setup-modules.ps1": "checksum-placeholder",
    ".teach/templates/philosophy-template.md": "checksum-placeholder",
    ".teach/templates/skill-definition-template.md": "checksum-placeholder",
    ".teach/templates/roadmap-template.md": "checksum-placeholder",
    ".teach/templates/modules-template.md": "checksum-placeholder",
    ".teach/templates/assessment-template.md": "checksum-placeholder"
  },
  "commands": {
    "create-new-skill": {
      "script": ".teach/scripts/powershell/create-new-skill.ps1",
      "description": "Create a new learning skill with directory structure",
      "usage": "create-new-skill.ps1 -SkillName <name>"
    },
    "setup-roadmap": {
      "script": ".teach/scripts/powershell/setup-roadmap.ps1",
      "description": "Generate learning roadmap from skill definition",
      "usage": "setup-roadmap.ps1 [-SkillId <id>]"
    },
    "setup-modules": {
      "script": ".teach/scripts/powershell/setup-modules.ps1",
      "description": "Break roadmap into detailed learning modules",
      "usage": "setup-modules.ps1 [-SkillId <id>]"
    },
    "check-prerequisites": {
      "script": ".teach/scripts/powershell/check-prerequisites.ps1",
      "description": "Validate prerequisites for learning workflow",
      "usage": "check-prerequisites.ps1 [-All] [-SkillId <id>]"
    }
  },
  "agents": {
    "teachme.philosophy": {
      "file": ".teach/agents/teachme.philosophy.agent.md",
      "description": "Create personalized learning philosophy",
      "workflow_step": 1
    },
    "teachme.define": {
      "file": ".teach/agents/teachme.define.agent.md",
      "description": "Define new skill with learning objectives",
      "workflow_step": 2
    },
    "teachme.assess": {
      "file": ".teach/agents/teachme.assess.agent.md",
      "description": "Assess current knowledge level",
      "workflow_step": 3
    },
    "teachme.roadmap": {
      "file": ".teach/agents/teachme.roadmap.agent.md",
      "description": "Create comprehensive learning roadmap",
      "workflow_step": 4
    },
    "teachme.validate": {
      "file": ".teach/agents/teachme.validate.agent.md",
      "description": "Validate learning path consistency",
      "workflow_step": 5
    },
    "teachme.modules": {
      "file": ".teach/agents/teachme.modules.agent.md",
      "description": "Generate detailed learning modules",
      "workflow_step": 6
    },
    "teachme.learn": {
      "file": ".teach/agents/teachme.learn.agent.md",
      "description": "Execute learning plan with AI guidance",
      "workflow_step": 7
    }
  },
  "workflow": {
    "name": "Teach Me Learning Workflow",
    "steps": [
      { "command": "/teachme.philosophy", "required": false, "description": "Define your learning principles" },
      { "command": "/teachme.define", "required": true, "description": "Create skill with objectives" },
      { "command": "/teachme.assess", "required": false, "description": "Evaluate current level" },
      { "command": "/teachme.roadmap", "required": true, "description": "Plan learning path" },
      { "command": "/teachme.validate", "required": false, "description": "Check consistency" },
      { "command": "/teachme.modules", "required": true, "description": "Create modules" },
      { "command": "/teachme.learn", "required": true, "description": "Start learning!" }
    ]
  },
  "directory_structure": {
    ".teach/": "System directory",
    ".teach/agents/": "AI agent workflow files",
    ".teach/templates/": "Learning document templates",
    ".teach/scripts/powershell/": "Automation scripts",
    ".teach/memory/": "Global learning context",
    ".teach/domains/": "Domain-specific templates",
    ".teach/integrations/": "Integration manifests",
    "skills/": "Individual skill directories",
    "skills/###-skill-name/": "Specific skill workspace",
    "skills/###-skill-name/exercises/": "Practice problems",
    "skills/###-skill-name/projects/": "Learning projects"
  },
  "compatibility": {
    "vscode": ">=1.80.0",
    "github_copilot": ">=1.0.0",
    "powershell": ">=7.0",
    "inspired_by": "spec-kit"
  }
}
